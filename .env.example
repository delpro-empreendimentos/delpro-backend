PYTHONPATH=src

# Public URL of the backend (used for WhatsApp webhook callbacks)
# On GCP VM: http://<VM_EXTERNAL_IP>:8000
BASE_URL=http://localhost:8000

# Docker image tag used by docker-compose.prod.yml
IMAGE_TAG=prod

# PostgreSQL
POSTGRES_USER=delpro
POSTGRES_PASSWORD=changeme
POSTGRES_DB=delpro_db
# Note: docker-compose overrides this with the container hostname (db)
DATABASE_URL=postgresql+asyncpg://delpro:changeme@localhost:5432/delpro_db

# PgAdmin (http://<host>:5050)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme

# Google Gemini
API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.5-flash

# LLM settings
LLM_TEMPERATURE=0
MAX_TOKENS=2000
MAX_HISTORY_MESSAGES=10

# RAG / Embeddings
EMBEDDING_MODEL=models/gemini-embedding-001
CHUNK_SIZE=500
CHUNK_OVERLAP=100
RAG_TOP_K=1
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_UPLOAD=5

# WhatsApp Business API (Meta)
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_APP_SECRET=your-app-secret
WHATSAPP_API_VERSION=v24.0

# Dev routing — local debug via ngrok (local only, não usar no VM)
NGROK_AUTHTOKEN=your-ngrok-authtoken
NGROK_DOMAIN=your-fixed-domain.ngrok-free.app
DEV_TUNNEL_URL=https://your-fixed-domain.ngrok-free.app
DEV_INTERNAL_TOKEN=any-random-secret
